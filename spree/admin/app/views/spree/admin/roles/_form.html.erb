<div class="card mb-6">
  <div class="card-body">
    <%= f.spree_text_field :name, required: true %>
  </div>
</div>

<div class="card mb-6">
  <div class="card-header">
    <h5 class="card-title">
      <%= Spree.t(:permissions) %>
    </h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive" data-controller="role-permissions">
      <table class="table">
        <thead>
          <tr>
            <th scope="col"><%= Spree.t(:resource) %></th>
            <% permission_actions.each do |action| %>
              <th scope="col" class="text-center"><%= Spree.t(action) %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% permission_resources.each do |resource| %>
            <% subject_class = resource[:subject_class] %>
            <tr>
              <td class="align-middle">
                <div class="flex flex-col gap-2">
                  <strong><%= resource[:label] %></strong>
                  <button type="button"
                          class="btn btn-light btn-sm w-fit"
                          data-action="click->role-permissions#toggleRow"
                          data-role-permissions-subject-param="<%= subject_class %>">
                    <%= Spree.t('admin.roles.toggle_all') %>
                  </button>
                </div>
              </td>
              <% permission_actions.each do |action| %>
                <% checked = selected_permissions.fetch(subject_class, []).include?(action) %>
                <% checkbox_id = "role_permissions_#{subject_class.underscore.tr('/', '_')}_#{action}" %>
                <td class="align-middle text-center">
                  <div class="form-checkbox inline-flex items-center justify-center">
                    <%= check_box_tag 'role[permissions][]',
                                      "#{subject_class}|#{action}",
                                      checked,
                                      id: checkbox_id,
                                      class: 'custom-control-input',
                                      data: { role_permissions_target: 'permissionCheckbox', subject_class: subject_class } %>
                    <%= label_tag checkbox_id, '', class: 'custom-control-label' %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
